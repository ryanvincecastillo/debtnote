# Shared Supabase (same project as Yes Honey, InaanApp, Avocado Go)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Tenant slug in public.projects
APP_PROJECT_ID=debtnote-dev

# Landing app (Next.js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Edge functions only — Resend API is shared; From address must be DEBTNOTE_FROM_EMAIL
RESEND_API_KEY=
DEBTNOTE_FROM_EMAIL=Debt Note App <noreply@ryanvincecastillo.com>
RESEND_FROM_EMAIL=

# Vercel Cron (apps/web) — set the same value in Vercel project env
CRON_SECRET=

# Invoking DebtNote edge functions from Next.js (match supabase secrets)
DEBTNOTE_EDGE_SECRET=
